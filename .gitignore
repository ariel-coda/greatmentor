node_modules/
.pnp
.pnp.js

# ─── Next.js ───────────────────────────────────────────
.next/
out/
build/

# ─── Variables d'environnement ─────────────────────────
# TRÈS IMPORTANT : ne jamais commit ces fichiers
# ils contiennent tes clés Supabase, Google, Mistral...
.env
.env.local
.env.development
.env.production
# .env.example est volontairement absent de cette liste
# car c'est un fichier modèle sans vraies clés — on le commit

# ─── Python / Backend FastAPI ──────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
.pytest_cache/

# ─── Logs ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

